<RootManager>:
    MeditationScreen:
        name: "meditation"
    StatsScreen:
        name: "stats"
    SettingsScreen:
        name: "settings"

<MeditationScreen>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: app.theme.background
            Rectangle:
                pos: self.pos
                size: self.size
                source: "assets/bg_gradient_dark.jpg"

        AnimatedCircle:
            id: circle
            size_hint: None, None
            size: "220dp", "220dp"
            pos_hint: {"center_x": 0.5, "center_y": 0.55}

        BoxLayout:
            orientation: "vertical"
            spacing: "8dp"
            size_hint: 0.9, None
            height: "136dp"
            pos_hint: {"center_x": 0.5, "top": 0.98}

            Label:
                text: "МЕДИТАЦИЯ"
                font_size: 32
                color: app.theme.primary
                size_hint_y: None
                height: "42dp"

            AnchorLayout:
                anchor_x: "center"
                anchor_y: "center"
                size_hint_y: None
                height: "44dp"

                Spinner:
                    id: duration_spinner
                    text: "Свободная"
                    values: root.duration_options
                    size_hint: None, None
                    size: "180dp", "44dp"
                    on_text: root.on_duration_mode_change(self.text)

            Label:
                id: timer_label
                text: "00:00"
                font_size: 24
                size_hint_y: None
                height: "32dp"

        BoxLayout:
            orientation: "vertical"
            spacing: "10dp"
            size_hint: 0.8, None
            height: "106dp"
            pos_hint: {"center_x": 0.5, "y": 0.16}

            Button:
                id: play_btn
                text: "Начать"
                size_hint_y: None
                height: "48dp"
                background_normal: ""
                background_color: app.theme.primary
                color: app.theme.text
                on_press: root.on_play_button_press(self)

            Button:
                id: finish_btn
                text: "Закончить"
                size_hint_y: None
                height: "48dp"
                background_normal: ""
                background_color: app.theme.primary
                color: app.theme.text
                opacity: 1 if root.show_finish_button else 0
                disabled: not root.show_finish_button
                on_press: root.on_finish_button_press()

        BoxLayout:
            orientation: "horizontal"
            spacing: "12dp"
            size_hint: 0.9, None
            height: "44dp"
            pos_hint: {"center_x": 0.5, "y": 0.03}

            Button:
                text: "Статистика"
                background_normal: ""
                background_color: app.theme.primary
                color: app.theme.text
                on_press: app.root.switch("stats")

            Button:
                text: "Настройки"
                background_normal: ""
                background_color: app.theme.primary
                color: app.theme.text
                on_press: app.root.switch("settings")
