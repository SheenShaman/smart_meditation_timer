 #:import dp kivy.metrics.dp
 #:import PieChartMonth widgets.animated_circle.PieChartMonth

RootManager:

<RootManager>:

    MeditationScreen:
        name: "meditation"
    StatsScreen:
        name: "stats"
    SettingsScreen:
        name: "settings"

<MeditationScreen>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: app.theme.background
            Rectangle:
                pos: self.pos
                size: self.size
                source: "assets/bg_gradient_dark.jpg"

        AnimatedCircle:
            id: circle
            size_hint: None, None
            size: "220dp", "220dp"
            pos_hint: {"center_x": 0.5, "center_y": 0.55}

        BoxLayout:
            orientation: "vertical"
            spacing: "8dp"
            size_hint: 0.9, None
            height: "136dp"
            pos_hint: {"center_x": 0.5, "top": 0.98}

            Label:
                text: "МЕДИТАЦИЯ"
                font_size: 32
                color: app.theme.primary
                size_hint_y: None
                height: "42dp"

            AnchorLayout:
                anchor_x: "center"
                anchor_y: "center"
                size_hint_y: None
                height: "44dp"

                Spinner:
                    id: duration_spinner
                    text: "Свободная"
                    values: root.duration_options
                    option_cls: "SpinnerOption"
                    size_hint: None, None
                    size: "180dp", "44dp"
                    background_normal: ""
                    background_down: ""
                    background_color: 0, 0, 0, 0
                    color: app.theme.text
                    on_text: root.on_duration_mode_change(self.text); root.sounds.play_click()
                    on_release: root.sounds.play_click()
                    canvas.before:
                        Color:
                            rgba: app.theme.glass_primary
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [14, 14, 14, 14]
                        Color:
                            rgba: app.theme.glass_border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 14)
                            width: 1.1
                    canvas.after:
                        Color:
                            rgba: app.theme.text
                        Triangle:
                            points:
                                [
                                self.right - dp(18), self.center_y + dp(4),
                                self.right - dp(8), self.center_y + dp(4),
                                self.right - dp(13), self.center_y - dp(3)
                                ]


            Label:
                id: timer_label
                text: "00:00"
                font_size: 24
                size_hint_y: None
                height: "32dp"

        BoxLayout:
            orientation: "vertical"
            spacing: "10dp"
            size_hint: 0.8, None
            height: "106dp"
            pos_hint: {"center_x": 0.5, "y": 0.16}

            Button:
                id: play_btn
                text: "Начать"
                size_hint_y: None
                height: "48dp"
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: app.theme.text
                on_press: root.on_play_button_press(self)
                canvas.before:
                    Color:
                        rgba: app.theme.glass_primary
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [14, 14, 14, 14]
                    Color:
                        rgba: app.theme.glass_border
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 14)
                        width: 1.1

            Button:
                id: finish_btn
                text: "Закончить"
                size_hint_y: None
                height: "48dp"
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: app.theme.text
                opacity: 1 if root.show_finish_button else 0
                disabled: not root.show_finish_button
                on_press: root.on_finish_button_press()
                canvas.before:
                    Color:
                        rgba: app.theme.glass_finish
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [14, 14, 14, 14]
                    Color:
                        rgba: app.theme.glass_border
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 14)
                        width: 1.1

        BoxLayout:
            orientation: "horizontal"
            spacing: "12dp"
            size_hint: 0.9, None
            height: "44dp"
            pos_hint: {"center_x": 0.5, "y": 0.03}

            Button:
                text: "Статистика"
                background_normal: ""
                background_color: app.theme.primary
                color: app.theme.text
                on_press: app.root.switch("stats")

                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: app.theme.text

                canvas.before:
                    Color:
                        rgba: app.theme.glass_primary
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [14, 14, 14, 14]

                    Color:
                        rgba: app.theme.glass_border
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 14)
                        width: 1.1

            Button:
                text: "Настройки"
                background_normal: ""
                background_color: app.theme.primary
                color: app.theme.text
                on_press: app.root.switch("settings")

                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: app.theme.text

                canvas.before:
                    Color:
                        rgba: app.theme.glass_primary
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [14, 14, 14, 14]

                    Color:
                        rgba: app.theme.glass_border
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 14)
                        width: 1.1

<FinishPopup@Popup>:
    title: ""
    background: ""
    background_color: 0, 0, 0, 0
    separator_height: 0
    separator_color: 0, 0, 0, 0
    overlay_color: 0, 0, 0, 0.9
    size_hint: None, None
    size: "340dp", "240dp"
    auto_dismiss: False
    pos_hint: {"center_x": 0.5, "center_y": 0.5}

    BoxLayout:
        orientation: "vertical"
        spacing: "10dp"
        padding: "16dp"
        canvas.before:
            Color:
                rgba: 0.08, 0.10, 0.14, 0.92
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [18, 18, 18, 18]
            Color:
                rgba: app.theme.glass_border
            Line:
                rounded_rectangle: (self.x, self.y, self.width, self.height, 18)
                width: 1.2

        Label:
            text: "Медитация завершена"
            color: app.theme.text
            font_size: "22sp"
            size_hint_y: None
            height: "36dp"
            halign: "center"
            valign: "middle"
            text_size: self.size

        Label:
            text: "Отличная работа"
            color: app.theme.text
            font_size: "16sp"
            size_hint_y: None
            height: "26dp"
            halign: "center"
            valign: "middle"
            text_size: self.size

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"

            Button:
                text: "Ок"
                size_hint: None, None
                size: "140dp", "44dp"
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: app.theme.text
                on_press: root.dismiss()
                canvas.before:
                    Color:
                        rgba: app.theme.glass_finish
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12, 12, 12, 12]
                    Color:
                        rgba: app.theme.glass_border
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 12)
                        width: 1.0

<StatsScreen>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: app.theme.background
            Rectangle:
                pos: self.pos
                size: self.size
                source: "assets/bg_gradient_dark.jpg"
     
        Label:
            text: "СТАТИСТИКА"
            font_size: 32
            color: app.theme.primary
            size_hint_y: None
            height: "42dp"
            pos_hint: {"center_x": 0.5, "top": 0.95}

        Spinner:
            id: month_spinner
            text: root.selected_month
            values: ["Январь", "Февраль", "Март", "Апрель", "Май", "Июнь", "Июль", "Август", "Сентябрь", "Октябрь", "Ноябрь", "Декабрь"]
            size_hint: None, None
            size: "170dp", "44dp"
            pos_hint: {"x": 0.08, "top": 0.88}
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            color: app.theme.text
            on_text: root.on_month_selected(self.text)

            canvas.before:
                Color:
                    rgba: app.theme.glass_primary
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [16, 16, 16, 16]

                Color:
                    rgba: app.theme.glass_border
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 16)
                    width: 1.1

        PieChartMonth:
            id: pie_chart
            size_hint: None, None
            size: "300dp", "300dp"
            pos_hint: {"center_x": 0.5, "center_y": 0.63}

        # контейнер легенды
        BoxLayout:
            id: legend_container
            orientation: "vertical"
            spacing: "12dp"
            size_hint: None, None
            size: "180dp", "120dp"
            pos_hint: {"x": 0.68, "center_y": 0.63}

            BoxLayout:
                id: legend_items
                orientation: "vertical"
                spacing: "12dp"
                size_hint_x: None
                size_hint_y: None
                height: "300dp"
                width: "180dp"
                padding: 0, "90dp", 0, 0

                # синяя медитация // Быстрая
                BoxLayout:
                    id: blue_meditation_item
                    spacing: "6dp"
                    size_hint_y: None
                    height: "28dp"

                    Widget:
                        size_hint: None, None
                        size: "16dp", "16dp"
                        canvas:
                            Color:
                                rgba: 0.40, 0.46, 0.92, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    Label:
                        text: "Быстрая"
                        color: app.theme.text
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                # фиолетовая медитация // Короткая
                BoxLayout:
                    id: purple_meditation_item
                    spacing: "6dp"
                    size_hint_y: None
                    height: "28dp"

                    Widget:
                        size_hint: None, None
                        size: "16dp", "16dp"
                        canvas:
                            Color:
                                rgba: 0.46, 0.30, 0.73, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    Label:
                        text: "Короткая"
                        color: app.theme.text
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                # розовая медитация // Глубокая
                BoxLayout:
                    id: pink_meditation_item
                    spacing: "6dp"
                    size_hint_y: None
                    height: "28dp"

                    Widget:
                        size_hint: None, None
                        size: "16dp", "16dp"
                        canvas:
                            Color:
                                rgba: 0.91, 0.33, 0.38, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    Label:
                        text: "Глубокая"
                        color: app.theme.text
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

        # дни недели
        BoxLayout:
            id: weekdays_row
            orientation: "horizontal"
            size_hint: 0.9, None
            height: "30dp"
            pos_hint: {"center_x": 0.5, "y": 0.32}
            spacing: "8dp"

            Label:
                text: "ПН"

            Label:
                text: "ВТ"

            Label:
                text: "СР"

            Label:
                text: "ЧТ"

            Label:
                text: "ПТ"

            Label:
                text: "СБ"

            Label:
                text: "ВС"

        # значения по дням
        BoxLayout:
            id: week_values_row
            orientation: "horizontal"
            size_hint: 0.9, None
            height: "30dp"
            pos_hint: {"center_x": 0.5, "y": 0.27}
            spacing: "8dp"

            Label:
                text: "5"

            Label:
                text: "12"

            Label:
                text: "8"

            Label:
                text: "15"

            Label:
                text: "20"

            Label:
                text: "18"

            Label:
                text: "25"

        Label:
            text: "Общее время: 2 ч 35 мин"
            font_size: "18sp"
            color: app.theme.text
            size_hint_y: None
            height: "30dp"
            pos_hint: {"center_x": 0.5, "y": 0.18}
            
        Button:
            text: "Назад"
            size_hint_y: None
            height: "48dp"
            size_hint_x: 0.8
            pos_hint: {"center_x": 0.5, "y": 0.05}
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            color: app.theme.text
            on_press: app.root.switch("meditation")

            canvas.before: 
                Color:
                    rgba: app.theme.glass_primary
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [14, 14, 14, 14]
                Color:
                    rgba: app.theme.glass_border
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 14)
                    width: 1.1
